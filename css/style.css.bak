#more {display: none;}


/* ========================Unmove navigation ========================*/

.nav {
  position: absolute;
  width: 1000px;
  float: left;
}
#navigation{top:90; }

      ul {
		list-style:none;
        padding-left: 0px;
        list-style: none;
        background:rgb(255,255,255);
		color:green;
    }
    ul li {
        display: inline-block;
        position: relative;
        line-height: 21px;
        text-align: left;
		font-family:Segoe UI Light;
		
    }
    ul li a {
		font-family:calibri;
        display: block;
        padding: 5px 30px;
        color: #000;
        text-decoration: none;
    }
		a{text-decoration:none;}
		a:visited{color:blue;}
		a:active{color:pink;}
		a:hover {color: #000;}
		
		
		ul li:hover {background:rgb(230,230,230);}
		
    ul li ul.dropdown {
		background:rgb(255,255,255);
        min-width: 100%;     /* Set width of the dropdown */
        display: none;
        position: absolute;
        z-index: 999;
		box-shadow: 0px 12px 12px 0px rgba(0,0,0,1);
    }
    ul li:hover ul.dropdown {

        display: block;      /* Display the dropdown */
    }
    ul li ul.dropdown li {

        display: block;
    }

	/* ==============Ordered list styling ==================*/
	ol{list-style: none; }


	    ol li a {
		font-family:calibri;
        display: block;
        padding: 0px;
        color: green;
    }



/*-----slide show  ----------------------------------------*/
	.slide {
  width: 995px;
  height: 350px;
  overflow: hidden;
  position: relative;
  background-color: #000;
}
.slide > div {
  width: 100%;
  height: 100%;
  background-size: 1000px 350px;
  position: absolute;
  animation: slide 25s infinite;
  opacity: 0;
}
.slide > div:nth-child(2) {
  animation-delay: 5s;
}
.slide > div:nth-child(3) {
  animation-delay: 10s;
}
.slide > div:nth-child(4) {
  animation-delay: 15s;
}
.slide > div:nth-child(5) {
  animation-delay: 20s;
}

@keyframes slide {
  10% {
    opacity: 1;
  }
  20% {
    opacity: 1;
  }
  30% {
    opacity: 0;
  }
  40% {
    transform: scale(1.15);
  }
}

section{padding-top:30px; padding-left:0px;}


	#right>marquee{height:400; padding-left:50PX;}
