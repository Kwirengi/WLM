.box-container {
  padding-left:13px;
  position: relative;
  width: 330px;
  display: flex;
  justify-content: right;
  flex-wrap: wrap;
  transform-style: preserve-3d;
  perspective: 500px;

}
.box-container .box {
  position: relative;
  width: 330px;
  height: 380px;
  background: #000;
  transition: 0.5s;
  transform-style: preserve-3d;
  overflow: hidden;
  margin-right: 15px;
  margin-top: 45px;
}
.box-container .box:hover {
  transform: rotateY(360deg) scale(1.5);
  z-index: 1;
  float:center;
  box-shadow: 0 25px 40px rgba(0,0,0,0.8);
}
.box-container .box .imgBx {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}
.box-container .box .imgBx:before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg,#f00,#000);
  z-index: 1;
  opacity: 0;
  transition: 0.5s;
  mix-blend-mode: multiply;
}
.box-container .box:hover .imgBx:before {
  opacity: 1;
}
.box-container .box .imgBx img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.box-container .box .box-content {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  display: flex;
  padding: 5px;
  align-items: flex-end;
  box-sizing: border-box;
}
.box-container .box .box-content h2 {
  color: blue;
  transition: 0.5s;
  text-transform: uppercase;
  text-align: center;
  margin-bottom: 5px;
  font-size: 20px;
  transform: translateY(200px);
  transition-delay: 0.3s;
}
.box-container .box:hover .box-content h2 {
  transform: translateY(0px);
}
.box-container .box .box-content p {
  color: #fff;
  text-align: center;
  transition: 0.5s;
  font-size: 14px;
  transform: translateY(200px);
  transition-delay: 0.5s;
}
.box-container .box:hover .box-content p {
  transform: translateY(0px);
}

